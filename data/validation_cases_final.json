    "duplicate_case_merge_2026_04": {
      "policy": "小写 pilot 键名（validation_cases_pilot 风格）与对应大写 Texaco_* 指同一物理工况时，仅保留大写条目；小写键已从本文件删除。",
      "removed_keys": [
        "texaco i-1",
        "texaco i-2",
        "texaco i-5c",
        "texaco i-10",
        "texaco exxon"
      ],
      "canonical_keys": [
        "Texaco_I-1",
        "Texaco_I-2",
        "Texaco_I-5C",
        "Texaco_I-10",
        "Texaco_Exxon"
      ],
      "why_not_identical_field_for_field": [
        "小写副本 heat_loss_percent=4（Fortran 小试约定），大写文献工况 heat_loss_percent=3（Wen & Chaung 原文）",
        "小写条目中 coal_feed_rate_kg_hr 数值实为 g/s（与 Fortran tfcoal 一致），大写使用 coal_feed_rate_kg_hr=g/s*3.6",
        "小写条目无 expected_results 干基气体组成；权威实验/模型预测仅在大写 Texaco_* 中维护"
      ],
      "code_alias": "src/model/validation_loader.py 中 CASE_NAME_ALIASES_FINAL：仍可用小写名 load_case_from_repo，映射到大写 canonical。"
    }
  },
